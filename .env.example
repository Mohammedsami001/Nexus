# ── Environment Configuration ─────────────────────────────────
# Copy this file to .env and modify as needed

# Simulator tick rate (readings per second)
TICK_RATE_HZ=1.0

# Probability of anomaly injection per tick (0.0–1.0)
ANOMALY_PROBABILITY=0.03

# Maximum number of readings kept in memory
BUFFER_SIZE=1000

# Number of readings before ML model trains
WARMUP_READINGS=200

# CORS allowed origins (comma-separated, use * for dev)
CORS_ORIGINS=*
